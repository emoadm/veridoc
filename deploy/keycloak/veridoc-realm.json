{
  "realm": "veridoc",
  "displayName": "VeriDoc AI",
  "enabled": true,
  "sslRequired": "external",
  "registrationAllowed": false,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "resetPasswordAllowed": true,
  "editUsernameAllowed": false,
  "bruteForceProtected": true,
  "permanentLockout": false,
  "maxFailureWaitSeconds": 900,
  "minimumQuickLoginWaitSeconds": 60,
  "waitIncrementSeconds": 60,
  "quickLoginCheckMilliSeconds": 1000,
  "maxDeltaTimeSeconds": 43200,
  "failureFactor": 5,
  "ssoSessionIdleTimeout": 1800,
  "ssoSessionMaxLifespan": 36000,
  "ssoSessionIdleTimeoutRememberMe": 0,
  "ssoSessionMaxLifespanRememberMe": 0,
  "offlineSessionIdleTimeout": 2592000,
  "accessTokenLifespan": 300,
  "accessTokenLifespanForImplicitFlow": 900,
  "actionTokenGeneratedByUserLifespan": 300,
  "attributes": {
    "acr.loa.map": "{\"mfa\":2,\"otp\":2,\"password\":1}"
  },
  "roles": {
    "realm": [
      {
        "name": "cra",
        "description": "Clinical Research Associate — performs source data verification, reviews discrepancies and agent findings, opens/closes queries for assigned sites.",
        "composite": false,
        "clientRole": false,
        "attributes": {
          "access_level": [
            "site-operational"
          ]
        }
      },
      {
        "name": "data-manager",
        "description": "Data Manager — manages eCRF data quality, query lifecycle and data cleaning across studies; broader study-level data access than a CRA.",
        "composite": false,
        "clientRole": false,
        "attributes": {
          "access_level": [
            "study-data"
          ]
        }
      },
      {
        "name": "medical-monitor",
        "description": "Medical Monitor — clinical oversight; receives all SAE escalations, reviews medical-significance findings and causality assessments.",
        "composite": false,
        "clientRole": false,
        "attributes": {
          "access_level": [
            "study-clinical"
          ]
        }
      },
      {
        "name": "site-coordinator",
        "description": "Site Coordinator — site-level study conduct and source-document custody; responds to queries for their own site only.",
        "composite": false,
        "clientRole": false,
        "attributes": {
          "access_level": [
            "site-operational"
          ]
        }
      },
      {
        "name": "principal-investigator",
        "description": "Principal Investigator — site clinical authority; reviews and signs off site findings, approves query resolutions for their site.",
        "composite": false,
        "clientRole": false,
        "attributes": {
          "access_level": [
            "site-clinical"
          ]
        }
      },
      {
        "name": "sponsor-rep",
        "description": "Sponsor Representative — read-only cross-site/study dashboards and reports; no write access to source data or queries.",
        "composite": false,
        "clientRole": false,
        "attributes": {
          "access_level": [
            "read-only-aggregate"
          ]
        }
      },
      {
        "name": "regulatory-affairs",
        "description": "Regulatory Affairs — audit-trail review (Annex 11), regulatory report access, compliance oversight; read access to the immutable audit log.",
        "composite": false,
        "clientRole": false,
        "attributes": {
          "access_level": [
            "audit-compliance"
          ]
        }
      },
      {
        "name": "system-admin",
        "description": "System Administrator — platform configuration, identity/realm administration, tenant provisioning; no clinical-decision authority (human-in-the-loop preserved).",
        "composite": false,
        "clientRole": false,
        "attributes": {
          "access_level": [
            "platform-admin"
          ]
        }
      }
    ]
  },
  "clients": [
    {
      "clientId": "reference-service",
      "name": "VeriDoc Reference Service",
      "description": "Walking-skeleton FastAPI service; confidential OIDC client (D-07).",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": false,
      "bearerOnly": false,
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": false,
      "serviceAccountsEnabled": false,
      "clientAuthenticatorType": "client-secret",
      "secret": "${REFERENCE_SERVICE_CLIENT_SECRET}",
      "redirectUris": [
        "https://reference-service.veridoc.local/*"
      ],
      "webOrigins": [
        "https://reference-service.veridoc.local"
      ],
      "attributes": {
        "access.token.signed.response.alg": "RS256",
        "pkce.code.challenge.method": "S256"
      },
      "protocolMappers": [
        {
          "name": "reference-service-audience",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-audience-mapper",
          "consentRequired": false,
          "config": {
            "included.client.audience": "reference-service",
            "id.token.claim": "false",
            "access.token.claim": "true"
          }
        },
        {
          "name": "realm-roles",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-realm-role-mapper",
          "consentRequired": false,
          "config": {
            "multivalued": "true",
            "userinfo.token.claim": "true",
            "id.token.claim": "false",
            "access.token.claim": "true",
            "claim.name": "realm_access.roles",
            "jsonType.label": "String"
          }
        },
        {
          "name": "tenant-site",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-attribute-mapper",
          "consentRequired": false,
          "config": {
            "user.attribute": "site",
            "userinfo.token.claim": "true",
            "id.token.claim": "false",
            "access.token.claim": "true",
            "claim.name": "site",
            "jsonType.label": "String"
          }
        },
        {
          "name": "tenant-study",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-attribute-mapper",
          "consentRequired": false,
          "config": {
            "user.attribute": "study",
            "userinfo.token.claim": "true",
            "id.token.claim": "false",
            "access.token.claim": "true",
            "claim.name": "study",
            "jsonType.label": "String"
          }
        }
      ]
    }
  ],
  "authenticationFlows": [
    {
      "alias": "browser-mfa",
      "description": "Browser flow with a REQUIRED OTP/MFA step (D-02).",
      "providerId": "basic-flow",
      "topLevel": true,
      "builtIn": false,
      "authenticationExecutions": [
        {
          "authenticator": "auth-cookie",
          "requirement": "ALTERNATIVE",
          "priority": 10,
          "userSetupAllowed": false,
          "autheticatorFlow": false
        },
        {
          "authenticator": "auth-username-password-form",
          "requirement": "REQUIRED",
          "priority": 20,
          "userSetupAllowed": false,
          "autheticatorFlow": false
        },
        {
          "authenticator": "auth-otp-form",
          "requirement": "REQUIRED",
          "priority": 30,
          "userSetupAllowed": true,
          "autheticatorFlow": false
        }
      ]
    }
  ],
  "browserFlow": "browser-mfa",
  "otpPolicyType": "totp",
  "otpPolicyAlgorithm": "HmacSHA1",
  "otpPolicyDigits": 6,
  "otpPolicyPeriod": 30,
  "otpPolicyLookAheadWindow": 1
}
